VITE_GAME_TITLE={{name}}
# VITE_API_BASE=

# Public canonical URL of the deployed site. Must end with "/".
# Local dev: http://localhost:3010/
# GH Pages project: https://<user>.github.io/<repo>/
# Custom domain:    https://example.com/
VITE_SITE_URL=http://localhost:3010/

# 40–300 chars. Goes into <meta name="description">, og:description, twitter:description.
VITE_SITE_DESCRIPTION=A mind-palace app built with TanStack Start, Jotai, and IndexedDB. Deployed static to GitHub Pages.

# Optional. Defaults to /og-card.svg (shipped). Override with an absolute URL or a /public/ path.
# VITE_OG_IMAGE=/og-card.svg

# Optional author attribution — shows in JSON-LD Person + meta[name="author"] + article:author.
# VITE_AUTHOR_NAME=
# VITE_AUTHOR_URL=
# VITE_TWITTER_HANDLE=

# Optional local source-linking Devtools. Leave unset by default: enabling this
# starts TanStack's dev-only source instrumentation during `bun run dev`.
# VITE_ENABLE_TANSTACK_DEVTOOLS=true
